[internationalization]

locale/translations=PackedStringArray("res://translation/ui_translation.en.translation", "res://translation/ui_translation.es.translation", "res://translation/dialogic_introduction_translation.en.translation", "res://translation/dialogic_introduction_translation.es.translation", "res://translation/dialogic_character_translations.es.translation", "res://translation/dialogic_character_translations.en.translation")
